<Window x:Class="SmartScanner.EditPageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="แก้ไขเอกสาร"
        WindowStartupLocation="Manual"
        Width="860" Height="640"
        Background="#94A3B8">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Toolbar ── -->
        <Border Grid.Row="0" Background="#1D4ED8" Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: modes, font size, colors, hint -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <ToggleButton x:Name="BtnTextMode" Click="BtnTextMode_Click"
                                  Padding="12,7" Margin="0,0,8,0" Cursor="Hand"
                                  FontSize="13" FontWeight="SemiBold" Foreground="White">
                        <ToggleButton.Template>
                            <ControlTemplate TargetType="ToggleButton">
                                <Border x:Name="Bd" CornerRadius="6" Padding="{TemplateBinding Padding}"
                                        Background="Transparent" BorderBrush="#60A5FA" BorderThickness="1">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#2563EB"/>
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="White"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#1E40AF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </ToggleButton.Template>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✏" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="เพิ่มข้อความ" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ToggleButton>

                    <ToggleButton x:Name="BtnEraseMode" Click="BtnEraseMode_Click"
                                  Padding="12,7" Margin="0,0,16,0" Cursor="Hand"
                                  FontSize="13" FontWeight="SemiBold" Foreground="White">
                        <ToggleButton.Template>
                            <ControlTemplate TargetType="ToggleButton">
                                <Border x:Name="Bd" CornerRadius="6" Padding="{TemplateBinding Padding}"
                                        Background="Transparent" BorderBrush="#60A5FA" BorderThickness="1">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#2563EB"/>
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="White"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#1E40AF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </ToggleButton.Template>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⬜" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="ลบข้อความ" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ToggleButton>

                    <!-- Font size -->
                    <TextBlock Text="ขนาด:" Foreground="#BFDBFE" FontSize="13"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox x:Name="CbFontSize" Width="65" Height="30" FontSize="13"
                              SelectionChanged="CbFontSize_SelectionChanged" SelectedIndex="2">
                        <ComboBoxItem Content="12"/>
                        <ComboBoxItem Content="16"/>
                        <ComboBoxItem Content="20"/>
                        <ComboBoxItem Content="24"/>
                        <ComboBoxItem Content="32"/>
                        <ComboBoxItem Content="48"/>
                    </ComboBox>

                    <!-- Color swatches -->
                    <TextBlock Text="สี:" Foreground="#BFDBFE" FontSize="13"
                               VerticalAlignment="Center" Margin="12,0,8,0"/>
                    <Border x:Name="SwatchBlack" Width="26" Height="26" CornerRadius="4"
                            Background="Black" BorderBrush="White" BorderThickness="2"
                            Cursor="Hand" Margin="0,0,4,0" ToolTip="สีดำ"
                            MouseLeftButtonDown="Swatch_Click" Tag="Black"/>
                    <Border x:Name="SwatchBlue" Width="26" Height="26" CornerRadius="4"
                            Background="#1E40AF" BorderBrush="Transparent" BorderThickness="2"
                            Cursor="Hand" Margin="0,0,4,0" ToolTip="สีน้ำเงิน"
                            MouseLeftButtonDown="Swatch_Click" Tag="Blue"/>
                    <Border x:Name="SwatchRed" Width="26" Height="26" CornerRadius="4"
                            Background="#EF4444" BorderBrush="Transparent" BorderThickness="2"
                            Cursor="Hand" Margin="0,0,0,0" ToolTip="สีแดง"
                            MouseLeftButtonDown="Swatch_Click" Tag="Red"/>

                    <!-- Hint -->
                    <TextBlock x:Name="HintText" Foreground="#93C5FD" FontSize="12" FontStyle="Italic"
                               VerticalAlignment="Center" Margin="16,0,0,0"
                               Text="เลือกโหมดแล้วคลิกบนเอกสาร"/>
                </StackPanel>

                <!-- Right: Save / Cancel -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="บันทึก" Click="BtnDone_Click"
                            Padding="16,8" Margin="0,0,8,0" Cursor="Hand"
                            FontSize="13" FontWeight="SemiBold" Foreground="White">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" CornerRadius="6" Padding="{TemplateBinding Padding}" Background="#059669">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#047857"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="ยกเลิก" Click="BtnCancel_Click"
                            Padding="14,8" Cursor="Hand" FontSize="13" Foreground="White">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" CornerRadius="6" Padding="{TemplateBinding Padding}"
                                        Background="Transparent" BorderBrush="#60A5FA" BorderThickness="1">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#1E40AF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Canvas scroll area ── -->
        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      Background="#64748B">
            <Border Margin="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.4" Color="Black"/>
                </Border.Effect>
                <Canvas x:Name="EditCanvas"
                        Background="White"
                        PreviewMouseLeftButtonDown="Canvas_PreviewMouseDown"
                        MouseMove="Canvas_MouseMove"
                        MouseLeftButtonUp="Canvas_MouseUp"/>
            </Border>
        </ScrollViewer>
    </Grid>
</Window>
