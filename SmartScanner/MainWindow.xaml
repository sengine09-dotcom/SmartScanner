<Window x:Class="SmartScanner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Smart Scanner to Email"
        Icon="Icon/logo_smart_scan.png"
        Height="720" Width="1020"
        MinHeight="600" MinWidth="820"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="{DynamicResource Th.Window.Bg}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Card -->
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Th.Card.Bg}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.09" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Field label -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource Th.Label.Fg}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- Input -->
        <Style x:Key="Input" TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Foreground" Value="{DynamicResource Th.Input.Fg}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource Th.Input.Fg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Th.Input.Border}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Background" Value="{DynamicResource Th.Input.Bg}"/>
        </Style>

        <!-- ComboBox -->
        <Style x:Key="Combo" TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Foreground" Value="{DynamicResource Th.Input.Fg}"/>
            <Setter Property="Background" Value="{DynamicResource Th.Input.Bg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Th.Input.Border}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="MainBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4">
                                <Grid>
                                    <ContentPresenter Margin="10,0,30,0"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      VerticalAlignment="Center"
                                                      IsHitTestVisible="False"/>
                                    <Path Data="M 0 0 L 6 6 L 12 0"
                                          Stroke="{TemplateBinding Foreground}"
                                          StrokeThickness="1.5"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Center"
                                          Margin="0,0,12,0"
                                          IsHitTestVisible="False"/>
                                </Grid>
                            </Border>
                            <ToggleButton IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide"
                                   Placement="Bottom"
                                   StaysOpen="False">
                                <Border Background="{DynamicResource Th.Input.Bg}"
                                        BorderBrush="{DynamicResource Th.Input.Border}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        MinWidth="{Binding ActualWidth, ElementName=MainBorder}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox dropdown items -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource Th.Input.Fg}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Th.Ghost.Bg.Hover}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Th.Thumb.Item.Selected.Bg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary blue button -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#1D4ED8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="16,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#1E40AF"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter Property="Background" Value="#9CA3AF"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Green send button -->
        <Style x:Key="SendBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#059669"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#047857"/></Trigger>
                <Trigger Property="IsEnabled" Value="False"><Setter Property="Background" Value="#9CA3AF"/></Trigger>
            </Style.Triggers>
        </Style>

        <!-- Purple save button -->
        <Style x:Key="SaveBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#7C3AED"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#6D28D9"/></Trigger>
                <Trigger Property="IsEnabled" Value="False"><Setter Property="Background" Value="#9CA3AF"/></Trigger>
            </Style.Triggers>
        </Style>

        <!-- Ghost button -->
        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Th.Ghost.Bg}"/>
            <Setter Property="Foreground" Value="{DynamicResource Th.Ghost.Fg}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Th.Ghost.Border}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="12,0"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Th.Ghost.Bg.Hover}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="{DynamicResource Th.Ghost.Bg.Disabled}"/>
                                <Setter Property="Foreground" Value="#9CA3AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="490" MinWidth="430"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="*" MinWidth="280"/>
        </Grid.ColumnDefinitions>

        <!-- ====== LEFT PANEL ====== -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="18,18,12,18">
            <StackPanel>

                <!-- Header banner -->
                <Border Background="#1D4ED8" CornerRadius="12" Padding="18,14" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Smart Scanner" FontSize="26" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="สแกนเอกสารและส่งทางอีเมล" FontSize="15" Foreground="#BFDBFE" Margin="0,5,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Dark mode toggle -->
                        <Button Command="{Binding ToggleThemeCommand}"
                                Cursor="Hand" Margin="0,0,8,0"
                                Background="Transparent" BorderThickness="1" BorderBrush="#60A5FA"
                                Foreground="White" FontSize="14" FontWeight="SemiBold" Padding="10,8">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#1E40AF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <TextBlock FontSize="15" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="🌙"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDarkMode}" Value="True">
                                                <Setter Property="Text" Value="☀"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button>
                        <Button x:Name="BtnSentItems" Click="BtnSentItems_Click"
                                Cursor="Hand" Margin="0,0,8,0"
                                Background="Transparent" BorderThickness="1" BorderBrush="#60A5FA"
                                Foreground="White" FontSize="14" FontWeight="SemiBold" Padding="12,8">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#1E40AF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📬" FontSize="15" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="ส่งแล้ว" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="1" x:Name="BtnSettings" Click="BtnSettings_Click"
                                VerticalAlignment="Center" Cursor="Hand"
                                Background="Transparent" BorderThickness="1" BorderBrush="#60A5FA"
                                Foreground="White" FontSize="14" FontWeight="SemiBold" Padding="12,8">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#1E40AF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x2699;" FontSize="16" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="ตั้งค่าอีเมล" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- SCANNER section -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Width="4" CornerRadius="2" Background="#1D4ED8" Margin="0,2,8,2"/>
                            <TextBlock Text="เครื่องสแกน" FontSize="15" FontWeight="Bold" Foreground="#1D4ED8" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="เลือกอุปกรณ์" Style="{StaticResource FieldLabel}"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0" Style="{StaticResource Combo}" Margin="0,0,8,0"
                                      ItemsSource="{Binding Scanners}" SelectedItem="{Binding SelectedScanner}"/>
                            <Button Grid.Column="1" Style="{StaticResource GhostBtn}" Content="รีเฟรช"
                                    Command="{Binding RefreshScannersCommand}"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                <TextBlock Text="ความละเอียด (DPI)" Style="{StaticResource FieldLabel}"/>
                                <ComboBox Style="{StaticResource Combo}" ItemsSource="{Binding DpiOptions}" SelectedItem="{Binding SelectedDpi}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                <TextBlock Text="โหมดสี" Style="{StaticResource FieldLabel}"/>
                                <ComboBox Style="{StaticResource Combo}" ItemsSource="{Binding ColorModes}" SelectedItem="{Binding SelectedColorMode}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Scan + Insert PDF buttons -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Style="{StaticResource PrimaryBtn}" Content="สแกนเอกสาร"
                            Command="{Binding ScanCommand}"/>
                    <Button Grid.Column="2" Style="{StaticResource GhostBtn}" Content="📄 เพิ่มจากไฟล์ PDF"
                            Command="{Binding InsertPdfCommand}" Padding="14,0"/></Grid>

                <!-- FILE section -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Width="4" CornerRadius="2" Background="#7C3AED" Margin="0,2,8,2"/>
                            <TextBlock Text="ชื่อไฟล์เอกสาร" FontSize="15" FontWeight="Bold" Foreground="#7C3AED" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="ชื่อไฟล์ (ไม่ต้องใส่นามสกุล .pdf)" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource Input}" Text="{Binding FileName, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Border>

                <!-- EMAIL section -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Width="4" CornerRadius="2" Background="#059669" Margin="0,2,8,2"/>
                            <TextBlock Text="ข้อมูลอีเมล" FontSize="15" FontWeight="Bold" Foreground="#059669" VerticalAlignment="Center"/>
                        </StackPanel>
                        <!-- Profile quick-pick -->
                        <TextBlock Text="โปรไฟล์อีเมล (Email Profile)" Style="{StaticResource FieldLabel}"/>
                        <ComboBox Style="{StaticResource Combo}" Margin="0,0,0,14"
                                  ItemsSource="{Binding EmailProfiles}"
                                  SelectedItem="{Binding SelectedEmailProfile}"
                                  DisplayMemberPath="Name">
                        </ComboBox>

                        <TextBlock Text="ผู้ส่ง (From)" Style="{StaticResource FieldLabel}"/>
                        <ComboBox Style="{StaticResource Combo}" Margin="0,0,0,10"
                                  ItemsSource="{Binding SenderProfiles}"
                                  SelectedItem="{Binding SelectedSender}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="2,4">
                                        <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource Th.Input.Fg}">
                                            <Run Text="{Binding DisplayName}"/>
                                        </TextBlock>
                                        <TextBlock Text="{Binding SenderEmail}" FontSize="12" Foreground="{DynamicResource Th.Muted.Fg}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBlock Text="ผู้รับ (To)" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="CbRecipient"
                                  Style="{StaticResource Combo}" Margin="0,0,0,10"
                                  ItemsSource="{Binding RecipientProfiles}"
                                  SelectedItem="{Binding SelectedRecipient}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="2,4">
                                        <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource Th.Input.Fg}"/>
                                        <TextBlock Text="{Binding Email}" FontSize="12" Foreground="{DynamicResource Th.Muted.Fg}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBlock Text="หัวเรื่อง (Subject)" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource Input}" Text="{Binding Subject, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                        <TextBlock Text="เนื้อหาอีเมล (Body)" Style="{StaticResource FieldLabel}"/>
                        <TextBox Height="80" Padding="10,8" FontSize="15"
                                 Foreground="{DynamicResource Th.Input.Fg}"
                                 BorderBrush="{DynamicResource Th.Input.Border}" BorderThickness="1.5"
                                 Background="{DynamicResource Th.Input.Bg}"
                                 TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                                 Text="{Binding Body, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Border>

                <!-- Action buttons -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Style="{StaticResource SaveBtn}" Content="บันทึก PDF"
                            Command="{Binding SavePdfCommand}"/>
                    <Button Grid.Column="2" Style="{StaticResource SendBtn}" Content="ส่งอีเมล"
                            Command="{Binding SendCommand}"/>
                </Grid>

                <!-- Progress bar -->
                <ProgressBar Height="6" IsIndeterminate="{Binding IsBusy}" Margin="0,0,0,8"
                             Foreground="#1D4ED8" Background="{DynamicResource Th.Progress.Bg}" BorderThickness="0"/>

                <!-- Status text -->
                <Border Background="{DynamicResource Th.Status.Bg}" CornerRadius="8" Padding="12,10" Margin="0,0,0,16"
                        BorderBrush="{DynamicResource Th.Status.Border}" BorderThickness="1">
                    <TextBlock Text="{Binding Status}" FontSize="15" Foreground="{DynamicResource Th.Status.Fg}"
                               FontWeight="SemiBold" TextWrapping="Wrap"/>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" Background="{DynamicResource Th.Splitter.Bg}"/>

        <!-- ====== RIGHT PANEL: Preview ====== -->
        <Grid Grid.Column="2" Background="{DynamicResource Th.RightPanel.Bg}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Preview header -->
            <Border Grid.Row="0" Background="#1D4ED8" Padding="16,13">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="ตัวอย่างเอกสาร" FontSize="17" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="{Binding PageCount}" FontSize="14" Foreground="#BFDBFE"/>
                    </StackPanel>
                    <Button Grid.Column="1" Style="{StaticResource GhostBtn}" Content="ล้างข้อมูล"
                            Command="{Binding ClearCommand}" IsEnabled="{Binding HasPreview}"
                            VerticalAlignment="Center" Background="Transparent"
                            Foreground="White" BorderBrush="#60A5FA"/>
                </Grid>
            </Border>

            <!-- Content: main preview + thumbnail strip -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- No preview placeholder -->
                <StackPanel Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding NoPreview, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="56"
                               Foreground="{DynamicResource Th.Placeholder.Icon}" HorizontalAlignment="Center" Margin="0,0,0,14"/>
                    <TextBlock Text="ยังไม่มีเอกสาร" FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource Th.Placeholder.Title}" HorizontalAlignment="Center"/>
                    <TextBlock Text="คลิก 'สแกนเอกสาร' เพื่อเริ่มต้น" FontSize="15"
                               Foreground="{DynamicResource Th.Placeholder.Subtitle}"
                               HorizontalAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>

                <!-- Main view: Viewbox fills full area, canvas scales uniformly -->
                <Grid Grid.Column="0" Background="{DynamicResource Th.Preview.Bg}"
                      Visibility="{Binding HasPreview, Converter={StaticResource BoolToVis}}">
                    <Viewbox Stretch="Uniform" Margin="14">
                        <Border>
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.14" Color="Black"/>
                            </Border.Effect>
                            <Canvas x:Name="MainEditCanvas"
                                    Background="White"
                                    PreviewMouseLeftButtonDown="EditCanvas_PreviewMouseDown"
                                    MouseMove="EditCanvas_MouseMove"
                                    MouseLeftButtonUp="EditCanvas_MouseUp"/>
                        </Border>
                    </Viewbox>
                </Grid>

                <!-- Thumbnail strip: mini pages with page numbers (drag to reorder) -->
                <Border x:Name="ThumbStrip" Grid.Column="1" Width="148"
                        Background="{DynamicResource Th.Thumb.Strip.Bg}"
                        BorderBrush="{DynamicResource Th.Thumb.Strip.Border}" BorderThickness="1,0,0,0"
                        Visibility="{Binding HasPreview, Converter={StaticResource BoolToVis}}"
                        PreviewMouseLeftButtonDown="ThumbStrip_MouseDown"
                        PreviewMouseMove="ThumbStrip_MouseMove"
                        MouseLeftButtonUp="ThumbStrip_MouseUp"
                        MouseLeave="ThumbStrip_MouseLeave">
                    <ScrollViewer x:Name="ThumbScroll" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled" Padding="6">
                        <ItemsControl x:Name="ThumbList" ItemsSource="{Binding PreviewPages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Margin="0,0,0,6" Padding="0" BorderThickness="0"
                                            Command="{Binding DataContext.SelectPageCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="ThumbBorder" CornerRadius="6" Padding="4"
                                                        Background="{DynamicResource Th.Thumb.Item.Bg}" BorderThickness="2" BorderBrush="Transparent">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="22"/>
                                                        </Grid.ColumnDefinitions>
                                                        <!-- Thumbnail: drag handle, image, page label -->
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="⠿" FontSize="14" Cursor="SizeNS"
                                                                       HorizontalAlignment="Center"
                                                                       Foreground="{DynamicResource Th.Thumb.Handle.Fg}"
                                                                       Margin="0,0,0,3" ToolTip="ลากเพื่อเรียงลำดับ"/>
                                                            <Image Source="{Binding Image}" Stretch="Uniform" MaxHeight="108"/>
                                                            <TextBlock Text="{Binding PageNumberLabel}" FontSize="11"
                                                                       FontWeight="SemiBold" HorizontalAlignment="Center"
                                                                       Margin="0,4,0,0"
                                                                       Foreground="{DynamicResource Th.Thumb.Label.Fg}"/>
                                                        </StackPanel>
                                                        <!-- Right-side action buttons -->
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="2,0,0,0">                                                            
                                                            <Border Tag="rotate-ccw" Width="20" Height="20" CornerRadius="9"
                                                                    Background="#6B7280" Cursor="Hand" ToolTip="หมุนซ้าย 90°"
                                                                    Margin="0,0,0,10">
                                                                <TextBlock Text="↺" FontSize="20" FontWeight="Bold"
                                                                           Foreground="White" HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center" IsHitTestVisible="False"/>
                                                            </Border>
                                                            <Border Tag="rotate-cw" Width="20" Height="20" CornerRadius="9"
                                                                    Background="#6B7280" Cursor="Hand" ToolTip="หมุนขวา 90°"
                                                                    Margin="0,0,0,10">
                                                                <TextBlock Text="↻" FontSize="20" FontWeight="Bold"
                                                                           Foreground="White" HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center" IsHitTestVisible="False"/>
                                                            </Border>
                                                            <Border Tag="delete" Width="20" Height="20" CornerRadius="9"
                                                                    Background="#EF4444" Cursor="Hand" ToolTip="ลบหน้านี้">
                                                                <TextBlock Text="✕" FontSize="9" FontWeight="Bold"
                                                                           Foreground="White" HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center" IsHitTestVisible="False"/>
                                                            </Border>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource Th.Thumb.Item.Hover.Bg}"/>
                                                    </Trigger>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="BorderBrush" Value="#1D4ED8"/>
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource Th.Thumb.Item.Selected.Bg}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsDragging}" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Opacity" Value="0.45"/>
                                                        <Setter TargetName="ThumbBorder" Property="BorderBrush" Value="#60A5FA"/>
                                                    </DataTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- ====== Editing toolbar ====== -->
            <Border Grid.Row="1" Background="#1E293B" Padding="14,8"
                    Visibility="{Binding HasPreview, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: mode + font + color + hint -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">

                        <ToggleButton x:Name="BtnMainTextMode" Click="BtnMainTextMode_Click"
                                      Padding="10,6" Margin="0,0,6,0" Cursor="Hand"
                                      FontSize="12" FontWeight="SemiBold" Foreground="White">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="Bd" CornerRadius="5" Padding="{TemplateBinding Padding}"
                                            Background="Transparent" BorderBrush="#475569" BorderThickness="1">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#2563EB"/>
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="#60A5FA"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#334155"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="✏" FontSize="13" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="เพิ่มข้อความ" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ToggleButton>

                        <ToggleButton x:Name="BtnMainEraseMode" Click="BtnMainEraseMode_Click"
                                      Padding="10,6" Margin="0,0,14,0" Cursor="Hand"
                                      FontSize="12" FontWeight="SemiBold" Foreground="White">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="Bd" CornerRadius="5" Padding="{TemplateBinding Padding}"
                                            Background="Transparent" BorderBrush="#475569" BorderThickness="1">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#2563EB"/>
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="#60A5FA"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#334155"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⬜" FontSize="13" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="ลบข้อความ" VerticalAlignment="Center"/>
                            </StackPanel>
                        </ToggleButton>

                        <Border Width="1" Background="#334155" VerticalAlignment="Stretch" Margin="0,0,14,0"/>

                        <TextBlock Text="ขนาด:" Foreground="#94A3B8" FontSize="12"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <ComboBox x:Name="CbMainFontSize" Width="58" Height="28" FontSize="12"
                                  SelectionChanged="CbMainFontSize_SelectionChanged" SelectedIndex="2">
                            <ComboBoxItem Content="12"/>
                            <ComboBoxItem Content="16"/>
                            <ComboBoxItem Content="20"/>
                            <ComboBoxItem Content="24"/>
                            <ComboBoxItem Content="32"/>
                            <ComboBoxItem Content="48"/>
                        </ComboBox>

                        <TextBlock Text="สี:" Foreground="#94A3B8" FontSize="12"
                                   VerticalAlignment="Center" Margin="12,0,8,0"/>
                        <Border x:Name="SwatchMainBlack" Width="22" Height="22" CornerRadius="4"
                                Background="Black" BorderBrush="White" BorderThickness="2"
                                Cursor="Hand" Margin="0,0,4,0" ToolTip="สีดำ"
                                MouseLeftButtonDown="MainSwatch_Click" Tag="Black"/>
                        <Border x:Name="SwatchMainBlue" Width="22" Height="22" CornerRadius="4"
                                Background="#1E40AF" BorderBrush="Transparent" BorderThickness="2"
                                Cursor="Hand" Margin="0,0,4,0" ToolTip="สีน้ำเงิน"
                                MouseLeftButtonDown="MainSwatch_Click" Tag="Blue"/>
                        <Border x:Name="SwatchMainRed" Width="22" Height="22" CornerRadius="4"
                                Background="#EF4444" BorderBrush="Transparent" BorderThickness="2"
                                Cursor="Hand" ToolTip="สีแดง"
                                MouseLeftButtonDown="MainSwatch_Click" Tag="Red"/>

                        <TextBlock x:Name="EditHintText" Foreground="#475569" FontSize="11" FontStyle="Italic"
                                   VerticalAlignment="Center" Margin="14,0,0,0"
                                   Text="เลือกโหมดแล้วคลิกบนเอกสาร"/>
                    </StackPanel>

                    <!-- Right: Save edits -->
                    <Button Grid.Column="1" x:Name="BtnSaveEdits" Click="BtnSaveEdits_Click"
                            Padding="14,7" Cursor="Hand" FontSize="12" FontWeight="SemiBold" Foreground="White">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" CornerRadius="6" Padding="{TemplateBinding Padding}" Background="#059669">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#047857"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💾" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="บันทึกการแก้ไข" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

        </Grid>
    </Grid>
</Window>
