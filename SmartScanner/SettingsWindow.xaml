<Window x:Class="SmartScanner.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ตั้งค่า SMTP / Email"
        Icon="Icon/logo_smart_scan.png"
        Height="680" Width="740"
        MinHeight="620" MinWidth="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanMinimize"
        Background="{DynamicResource Th.Window.Bg}"
        Foreground="{DynamicResource Th.Body.Fg}">

    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource Th.Label.Fg}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="Input" TargetType="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource Th.Input.Fg}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource Th.Input.Fg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Th.Input.Border}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Background" Value="{DynamicResource Th.Input.Bg}"/>
        </Style>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="12,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.85"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.4"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ListItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Th.Thumb.Item.Selected.Bg}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#D97706" CornerRadius="10" Padding="16,12" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="ตั้งค่า SMTP / Email" FontSize="20" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="กำหนดค่าเซิร์ฟเวอร์ รายชื่อผู้ส่ง และรายชื่อผู้รับ" FontSize="13" Foreground="#FEF3C7" Margin="0,3,0,0"/>
            </StackPanel>
        </Border>

        <!-- TabControl -->
        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">

            <!-- ══════════════════ TAB 1: SMTP & Senders ══════════════════ -->
            <TabItem FontSize="14" FontWeight="SemiBold" Padding="14,8">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📤 " FontSize="14"/>
                        <TextBlock Text="ผู้ส่งอีเมล" FontSize="14" FontWeight="SemiBold"/>
                    </StackPanel>
                </TabItem.Header>

                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- SMTP Card -->
                    <Border Grid.Row="0" Background="{DynamicResource Th.Card.Bg}" CornerRadius="10" Padding="14" Margin="0,0,0,10">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.08" Color="Black"/>
                        </Border.Effect>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Border Width="4" CornerRadius="2" Background="#D97706" Margin="0,2,8,2"/>
                                <TextBlock Text="เซิร์ฟเวอร์ SMTP (ใช้ร่วมกันทุกอีเมล)" FontSize="13" FontWeight="Bold" Foreground="#D97706" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock Text="SMTP Server" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="TbSmtpHost" Style="{StaticResource Input}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="0,0,16,0">
                                    <TextBlock Text="Port" Style="{StaticResource FieldLabel}"/>
                                    <TextBox x:Name="TbSmtpPort" Style="{StaticResource Input}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" VerticalAlignment="Bottom" Margin="0,0,0,6">
                                    <CheckBox x:Name="ChkSsl" Content="SSL / TLS" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource Th.Ghost.Fg}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Senders Card -->
                    <Border Grid.Row="1" Background="{DynamicResource Th.Card.Bg}" CornerRadius="10" Padding="14">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.08" Color="Black"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                                <Border Width="4" CornerRadius="2" Background="#059669" Margin="0,2,8,2"/>
                                <TextBlock Text="รายชื่ออีเมลผู้ส่ง" FontSize="13" FontWeight="Bold" Foreground="#059669" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Sender list -->
                                <Grid Grid.Column="0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <ListBox Grid.Row="0" x:Name="LbSenders" Margin="0,0,0,8"
                                             BorderBrush="{DynamicResource Th.ListBox.Border}" BorderThickness="1.5"
                                             Background="{DynamicResource Th.ListBox.Bg}"
                                             SelectionChanged="LbSenders_SelectionChanged"
                                             ItemContainerStyle="{StaticResource ListItem}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="4,5">
                                                    <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource Th.Input.Fg}"/>
                                                    <TextBlock Text="{Binding SenderEmail}" FontSize="11" Foreground="{DynamicResource Th.Muted.Fg}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <StackPanel Grid.Row="1" Orientation="Horizontal">
                                        <Button x:Name="BtnAdd" Style="{StaticResource ActionBtn}" Background="#059669" Foreground="White" Content="+ เพิ่ม" Width="75" Click="BtnAdd_Click" Margin="0,0,6,0"/>
                                        <Button x:Name="BtnDelete" Style="{StaticResource ActionBtn}" Background="#EF4444" Foreground="White" Content="ลบ" Width="65" Click="BtnDelete_Click" IsEnabled="False"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Sender edit form -->
                                <Grid Grid.Column="2">
                                    <StackPanel x:Name="PanelPlaceholder" VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="📧" FontSize="36" HorizontalAlignment="Center"/>
                                        <TextBlock Text="เลือกผู้ส่งจากรายการ" FontSize="13" Foreground="{DynamicResource Th.Subtle.Fg}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                        <TextBlock Text="หรือคลิก '+ เพิ่ม'" FontSize="12" Foreground="{DynamicResource Th.Placeholder.Subtitle}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <Border x:Name="PanelForm" Visibility="Collapsed" Background="{DynamicResource Th.Form.Panel.Bg}" CornerRadius="8" Padding="12">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                            <StackPanel>
                                                <TextBlock x:Name="TbFormTitle" FontSize="13" FontWeight="Bold" Foreground="#1D4ED8" Margin="0,0,0,10"/>
                                                <TextBlock Text="ชื่อที่แสดง (Display Name)" Style="{StaticResource FieldLabel}"/>
                                                <TextBox x:Name="FDisplayName" Style="{StaticResource Input}" Margin="0,0,0,8"/>
                                                <TextBlock Text="อีเมลผู้ส่ง (From Email)" Style="{StaticResource FieldLabel}"/>
                                                <TextBox x:Name="FSenderEmail" Style="{StaticResource Input}" Margin="0,0,0,8"/>
                                                <TextBlock Text="ชื่อผู้ใช้ SMTP (Username)" Style="{StaticResource FieldLabel}"/>
                                                <TextBox x:Name="FUsername" Style="{StaticResource Input}" Margin="0,0,0,8"/>
                                                <TextBlock Text="รหัสผ่าน (Password)" Style="{StaticResource FieldLabel}"/>
                                                <Grid Margin="0,0,0,12">
                                                    <PasswordBox x:Name="FPassword" Height="36" Padding="10,7" FontSize="13"
                                                                 Foreground="{DynamicResource Th.Input.Fg}"
                                                                 BorderBrush="{DynamicResource Th.Input.Border}" BorderThickness="1.5"
                                                                 Background="{DynamicResource Th.Input.Bg}"/>
                                                    <TextBox x:Name="FPasswordText" Height="36" Padding="10,7" FontSize="13"
                                                             Foreground="{DynamicResource Th.Input.Fg}"
                                                             BorderBrush="{DynamicResource Th.Input.Border}" BorderThickness="1.5"
                                                             Background="{DynamicResource Th.Input.Bg}" Visibility="Collapsed"/>
                                                    <Button x:Name="BtnTogglePass" Width="36" Height="36" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" FontSize="15" Cursor="Hand" Content="👁" Click="BtnTogglePass_Click"/>
                                                </Grid>
                                                <Button x:Name="BtnSaveSender" Style="{StaticResource ActionBtn}" Background="#1D4ED8" Foreground="White" Content="บันทึกผู้ส่ง" Height="34" Click="BtnSaveSender_Click"/>
                                                <TextBlock x:Name="TbFormStatus" FontSize="12" FontWeight="SemiBold" Margin="0,8,0,0" TextWrapping="Wrap" Visibility="Collapsed"/>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ══════════════════ TAB 2: Recipients ══════════════════ -->
            <TabItem FontSize="14" FontWeight="SemiBold" Padding="14,8">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📥 " FontSize="14"/>
                        <TextBlock Text="รายชื่อผู้รับ" FontSize="14" FontWeight="SemiBold"/>
                    </StackPanel>
                </TabItem.Header>

                <Border Margin="0,10,0,0" Background="{DynamicResource Th.Card.Bg}" CornerRadius="10" Padding="14">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.08" Color="Black"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                            <Border Width="4" CornerRadius="2" Background="#7C3AED" Margin="0,2,8,2"/>
                            <TextBlock Text="รายชื่ออีเมลผู้รับ" FontSize="13" FontWeight="Bold" Foreground="#7C3AED" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Recipient list -->
                            <Grid Grid.Column="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <ListBox Grid.Row="0" x:Name="LbRecipients" Margin="0,0,0,8"
                                         BorderBrush="{DynamicResource Th.ListBox.Border}" BorderThickness="1.5"
                                         Background="{DynamicResource Th.ListBox.Bg}"
                                         SelectionChanged="LbRecipients_SelectionChanged"
                                         ItemContainerStyle="{StaticResource ListItem}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="4,5">
                                                <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource Th.Input.Fg}"/>
                                                <TextBlock Text="{Binding Email}" FontSize="11" Foreground="{DynamicResource Th.Muted.Fg}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <StackPanel Grid.Row="1" Orientation="Horizontal">
                                    <Button x:Name="BtnAddRec" Style="{StaticResource ActionBtn}" Background="#7C3AED" Foreground="White" Content="+ เพิ่ม" Width="75" Click="BtnAddRec_Click" Margin="0,0,6,0"/>
                                    <Button x:Name="BtnDeleteRec" Style="{StaticResource ActionBtn}" Background="#EF4444" Foreground="White" Content="ลบ" Width="65" Click="BtnDeleteRec_Click" IsEnabled="False"/>
                                </StackPanel>
                            </Grid>

                            <!-- Recipient edit form -->
                            <Grid Grid.Column="2">
                                <StackPanel x:Name="RecPlaceholder" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="👤" FontSize="36" HorizontalAlignment="Center"/>
                                    <TextBlock Text="เลือกผู้รับจากรายการ" FontSize="13" Foreground="{DynamicResource Th.Subtle.Fg}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                    <TextBlock Text="หรือคลิก '+ เพิ่ม'" FontSize="12" Foreground="{DynamicResource Th.Placeholder.Subtitle}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                                <Border x:Name="RecForm" Visibility="Collapsed" Background="{DynamicResource Th.Form.Panel.Bg}" CornerRadius="8" Padding="12">
                                    <StackPanel>
                                        <TextBlock x:Name="TbRecFormTitle" FontSize="13" FontWeight="Bold" Foreground="#7C3AED" Margin="0,0,0,10"/>
                                        <TextBlock Text="ชื่อ (Name)" Style="{StaticResource FieldLabel}"/>
                                        <TextBox x:Name="RName" Style="{StaticResource Input}" Margin="0,0,0,10"/>
                                        <TextBlock Text="อีเมล (Email) *" Style="{StaticResource FieldLabel}"/>
                                        <TextBox x:Name="REmail" Style="{StaticResource Input}" Margin="0,0,0,14"/>
                                        <Button x:Name="BtnSaveRec" Style="{StaticResource ActionBtn}" Background="#7C3AED" Foreground="White" Content="บันทึกผู้รับ" Height="34" Click="BtnSaveRec_Click"/>
                                        <TextBlock x:Name="TbRecStatus" FontSize="12" FontWeight="SemiBold" Margin="0,8,0,0" TextWrapping="Wrap" Visibility="Collapsed"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>
            </TabItem>

            <!-- ══════════════════ TAB 3: Email Profiles ══════════════════ -->
            <TabItem FontSize="14" FontWeight="SemiBold" Padding="14,8">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📋 " FontSize="14"/>
                        <TextBlock Text="โปรไฟล์อีเมล" FontSize="14" FontWeight="SemiBold"/>
                    </StackPanel>
                </TabItem.Header>

                <Border Margin="0,10,0,0" Background="{DynamicResource Th.Card.Bg}" CornerRadius="10" Padding="14">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.08" Color="Black"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                            <Border Width="4" CornerRadius="2" Background="#0891B2" Margin="0,2,8,2"/>
                            <TextBlock Text="บันทึกชุดข้อมูลอีเมลสำหรับใช้งานซ้ำ" FontSize="13" FontWeight="Bold" Foreground="#0891B2" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Profile list -->
                            <Grid Grid.Column="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <ListBox Grid.Row="0" x:Name="LbProfiles" Margin="0,0,0,8"
                                         BorderBrush="{DynamicResource Th.ListBox.Border}" BorderThickness="1.5"
                                         Background="{DynamicResource Th.ListBox.Bg}"
                                         SelectionChanged="LbProfiles_SelectionChanged"
                                         ItemContainerStyle="{StaticResource ListItem}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource Th.Input.Fg}" Margin="4,6"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <StackPanel Grid.Row="1" Orientation="Horizontal">
                                    <Button x:Name="BtnAddProfile" Style="{StaticResource ActionBtn}" Background="#0891B2" Foreground="White" Content="+ เพิ่ม" Width="75" Click="BtnAddProfile_Click" Margin="0,0,6,0"/>
                                    <Button x:Name="BtnDeleteProfile" Style="{StaticResource ActionBtn}" Background="#EF4444" Foreground="White" Content="ลบ" Width="65" Click="BtnDeleteProfile_Click" IsEnabled="False"/>
                                </StackPanel>
                            </Grid>

                            <!-- Profile edit form -->
                            <Grid Grid.Column="2">
                                <StackPanel x:Name="ProfilePlaceholder" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="📋" FontSize="36" HorizontalAlignment="Center"/>
                                    <TextBlock Text="เลือกโปรไฟล์จากรายการ" FontSize="13" Foreground="{DynamicResource Th.Subtle.Fg}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                    <TextBlock Text="หรือคลิก '+ เพิ่ม'" FontSize="12" Foreground="{DynamicResource Th.Placeholder.Subtitle}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                                <Border x:Name="ProfileForm" Visibility="Collapsed" Background="{DynamicResource Th.Form.Panel.Bg}" CornerRadius="8" Padding="12">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                        <StackPanel>
                                            <TextBlock x:Name="TbProfileFormTitle" FontSize="13" FontWeight="Bold" Foreground="#0891B2" Margin="0,0,0,10"/>
                                            <TextBlock Text="ชื่อโปรไฟล์ *" Style="{StaticResource FieldLabel}"/>
                                            <TextBox x:Name="PfName" Style="{StaticResource Input}" Margin="0,0,0,8"/>
                                            <TextBlock Text="ผู้ส่ง (From) *" Style="{StaticResource FieldLabel}"/>
                                            <ComboBox x:Name="PfFrom" Height="36" FontSize="13" Margin="0,0,0,8"
                                                      BorderBrush="{DynamicResource Th.Input.Border}" BorderThickness="1.5">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Margin="2,3">
                                                            <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold"/>
                                                            <TextBlock Text="{Binding SenderEmail}" FontSize="11" Foreground="{DynamicResource Th.Muted.Fg}"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                            <TextBlock Text="ผู้รับ (To) *" Style="{StaticResource FieldLabel}"/>
                                            <ComboBox x:Name="PfToCombo" Height="36" FontSize="13" Margin="0,0,0,4"
                                                      BorderBrush="{DynamicResource Th.Input.Border}" BorderThickness="1.5"
                                                      SelectionChanged="PfToCombo_SelectionChanged">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Margin="2,3">
                                                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"/>
                                                            <TextBlock Text="{Binding Email}" FontSize="11" Foreground="{DynamicResource Th.Muted.Fg}"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                            <TextBox x:Name="PfTo" Style="{StaticResource Input}" Margin="0,0,0,8"
                                                     ToolTip="พิมพ์อีเมลหรือเลือกจากรายการด้านบน"/>
                                            <TextBlock Text="หัวเรื่อง (Subject)" Style="{StaticResource FieldLabel}"/>
                                            <TextBox x:Name="PfSubject" Style="{StaticResource Input}" Margin="0,0,0,8"/>
                                            <TextBlock Text="เนื้อหา (Body)" Style="{StaticResource FieldLabel}"/>
                                            <TextBox x:Name="PfBody" Height="80" Padding="10,8" FontSize="13"
                                                     Foreground="{DynamicResource Th.Input.Fg}"
                                                     BorderBrush="{DynamicResource Th.Input.Border}" BorderThickness="1.5"
                                                     Background="{DynamicResource Th.Input.Bg}"
                                                     TextWrapping="Wrap" AcceptsReturn="True"
                                                     VerticalScrollBarVisibility="Auto" Margin="0,0,0,12"/>
                                            <Button x:Name="BtnSaveProfile" Style="{StaticResource ActionBtn}" Background="#0891B2" Foreground="White" Content="บันทึกโปรไฟล์" Height="34" Click="BtnSaveProfile_Click"/>
                                            <TextBlock x:Name="TbProfileStatus" FontSize="12" FontWeight="SemiBold" Margin="0,8,0,0" TextWrapping="Wrap" Visibility="Collapsed"/>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>
            </TabItem>

            <!-- ══════════════════ TAB 4: File Storage ══════════════════ -->
            <TabItem FontSize="14" FontWeight="SemiBold" Padding="14,8">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🗂 " FontSize="14"/>
                        <TextBlock Text="จัดเก็บไฟล์" FontSize="14" FontWeight="SemiBold"/>
                    </StackPanel>
                </TabItem.Header>

                <ScrollViewer Margin="0,10,0,0" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Appearance card -->
                        <Border Background="{DynamicResource Th.Card.Bg}" CornerRadius="10" Padding="14" Margin="0,0,0,12">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.08" Color="Black"/>
                            </Border.Effect>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Border Width="4" CornerRadius="2" Background="#7C3AED" Margin="0,2,8,2"/>
                                    <TextBlock Text="รูปแบบการแสดงผล" FontSize="13" FontWeight="Bold" Foreground="#7C3AED" VerticalAlignment="Center"/>
                                </StackPanel>
                                <CheckBox x:Name="ChkDarkMode"
                                          Content="โหมดมืด (Dark Mode)"
                                          FontSize="13" FontWeight="SemiBold"
                                          Foreground="{DynamicResource Th.Ghost.Fg}"
                                          Checked="ChkDarkMode_Changed"
                                          Unchecked="ChkDarkMode_Changed"/>
                            </StackPanel>
                        </Border>

                        <!-- Archive folder card -->
                        <Border Background="{DynamicResource Th.Card.Bg}" CornerRadius="10" Padding="14" Margin="0,0,0,12">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.08" Color="Black"/>
                            </Border.Effect>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Border Width="4" CornerRadius="2" Background="#D97706" Margin="0,2,8,2"/>
                                    <TextBlock Text="โฟลเดอร์สำหรับเก็บไฟล์ PDF ที่ส่งแล้ว" FontSize="13" FontWeight="Bold" Foreground="#D97706" VerticalAlignment="Center"/>
                                </StackPanel>

                                <TextBlock Text="ที่อยู่โฟลเดอร์" Style="{StaticResource FieldLabel}"/>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TbArchivePath" Grid.Column="0" Style="{StaticResource Input}"
                                             IsReadOnly="True" Background="{DynamicResource Th.Form.Panel.Bg}"
                                             ToolTip="กดปุ่ม 'เลือกโฟลเดอร์' เพื่อตั้งค่า"/>
                                    <Button Grid.Column="2" x:Name="BtnBrowseArchive"
                                            Style="{StaticResource ActionBtn}"
                                            Background="#D97706" Foreground="White"
                                            Content="📁  เลือกโฟลเดอร์" Height="36"
                                            Click="BtnBrowseArchive_Click"/>
                                </Grid>

                                <Button x:Name="BtnOpenArchiveFolder"
                                        Style="{StaticResource ActionBtn}"
                                        Background="#6B7280" Foreground="White"
                                        Content="🔍  เปิดโฟลเดอร์" Height="34" HorizontalAlignment="Left"
                                        Click="BtnOpenArchiveFolder_Click"/>
                            </StackPanel>
                        </Border>

                        <!-- Info card -->
                        <Border Background="{DynamicResource Th.Info.Bg}" CornerRadius="10" Padding="14"
                                BorderBrush="{DynamicResource Th.Info.Border}" BorderThickness="1.5">
                            <StackPanel>
                                <TextBlock Text="ℹ️  หมายเหตุ" FontSize="13" FontWeight="Bold"
                                           Foreground="{DynamicResource Th.Info.Title.Fg}" Margin="0,0,0,8"/>
                                <TextBlock TextWrapping="Wrap" FontSize="13"
                                           Foreground="{DynamicResource Th.Info.Body.Fg}" LineHeight="22">
                                    <Run Text="• ไฟล์ PDF จะถูกบันทึกลงโฟลเดอร์ที่ตั้งค่าไว้ทุกครั้งที่ส่งอีเมลสำเร็จ"/>
                                    <LineBreak/>
                                    <Run Text="• ชื่อไฟล์จะไม่ซ้ำกัน — หากชื่อซ้ำจะเพิ่ม _1, _2, ... ต่อท้ายอัตโนมัติ"/>
                                    <LineBreak/>
                                    <Run Text="• เมื่อลบรายการในหน้า 'อีเมลที่ส่งแล้ว' ไฟล์ PDF จะถูกลบออกจากโฟลเดอร์นี้ด้วย"/>
                                    <LineBreak/>
                                    <Run Text="• หากไม่ได้ตั้งค่าโฟลเดอร์ ระบบจะยังคงบันทึกประวัติการส่งไว้ แต่ไม่เก็บไฟล์ PDF"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Footer -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="ยกเลิก" Click="BtnCancel_Click"
                    Height="42" FontSize="15" FontWeight="SemiBold" Cursor="Hand"
                    Background="{DynamicResource Th.Ghost.Bg}"
                    Foreground="{DynamicResource Th.Ghost.Fg}"
                    BorderThickness="1" BorderBrush="{DynamicResource Th.Ghost.Border}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Th.Ghost.Bg.Hover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Grid.Column="2" Content="บันทึกทั้งหมด" Click="BtnSaveAll_Click"
                    Height="42" FontSize="15" FontWeight="SemiBold" Cursor="Hand"
                    Background="#D97706" Foreground="White" BorderThickness="0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#B45309"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Grid>
</Window>
